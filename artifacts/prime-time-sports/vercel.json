{
  "framework": "vite",
  "buildCommand": "cd ../.. && pnpm --filter @workspace/prime-time-sports run build",
  "installCommand": "cd ../.. && pnpm install",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
