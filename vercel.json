{
  "buildCommand": "node vercel-build.mjs",
  "outputDirectory": "artifacts/prime-time-sports/dist/public",
  "installCommand": "echo 'deps handled in build script'",
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
